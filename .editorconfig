# EditorConfig is awesome: http://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_file = lf
insert_final_newline = true
indent_style = space
indent_size = 4
max_line_length = 120
quote_type = single
trim_trailing_whitespace = true

# Tab indentation (no size specified)
[Makefile]
indent_style = tab

## Markdown
[*.md]
trim_trailing_whitespace = false
indent_size = 1

# Python
[*.py]
indent_style = space
indent_size = 4

# Ruby
[{*.rb,*.gemspec,Gemfile{,.lock},Rakefile,Vagrantfile}]
indent_size = 2

# Front End Languages (HTML, JS, CSS etc)
[*.{js, css, html}]
indent_style = space
indent_size = 2
charset = utf-8
trim_trailing_whitespace = true

[*.json]
quote_type = double

# Auto-generated manifest files contain long SHA hashes that cannot be wrapped
[*.manifest.json]
max_line_length = off

# YAML Based files - 2 space indent
[*.yml]
indent_size = 2
indent_style = space

[*.yaml]
indent_size = 2
indent_style = space

[*.{js,json}]
indent_size = 2
indent_style = space

[*.{swift,swift.gyb,cpp,h}]
indent_style = space
# tab_width = 4
indent_size = 1

[*.sh]
indent_style = space
indent_size = 2

[*.xcscheme]
indent_style = space
indent_size = 1

[*.xcworkspacedata]
indent_style = space
indent_size = 1

[*.pbxproj]
max_line_length = off

# Exclude auto-generated or Claude-specific directories from linting
[{.claude/**,.gemini/**,.specify/**}]
max_line_length = off
indent_size = -1

# Template files — inherit rules matching the format they represent
[*.yml.template]
indent_size = 2
indent_style = space

[*.yaml.template]
indent_size = 2
indent_style = space

[*.plist.template]
indent_size = 4
indent_style = space
